{
  "name": "leduo-patrol",
  "version": "1.1.1",
  "description": "乐多汪汪队（leduo-patrol）web console for driving Claude Code over ACP.",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts --mode=server",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "rm -rf dist/server && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js --mode=server",
    "check": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "tsx --test server/__tests__/*.test.ts src/__tests__/*.test.ts",
    "prepack": "npm run build",
    "dev:local": "concurrently -k \"npm:dev:web:local\" \"npm:dev:server:local\"",
    "dev:web:local": "vite --host 127.0.0.1",
    "dev:server:local": "tsx watch server/index.ts --mode=local",
    "start:local": "node dist/server/index.js --mode=local"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@zed-industries/claude-code-acp": "^0.16.2",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "bin": {
    "leduo-patrol": "dist/server/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
